    - id: 36
      fields:
      - title: Title
        value: 
        type: 0
        typeString: 
      - title: Description
        value: 
        type: 0
        typeString: 
      - title: Actor
        value: 7
        type: 0
        typeString: CustomFieldType_Actor
      - title: Conversant
