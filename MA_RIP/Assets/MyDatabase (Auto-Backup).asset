      - title: Menu Text
        value: 
        type: 0
        typeString: 
      - title: Dialogue Text
        value: 'Now, let me explain why I am here:'
        type: 0
        typeString: 
      - title: Sequence
        value: 
        type: 0
        typeString: 
      conversationID: 1
      isRoot: 0
      isGroup: 0
