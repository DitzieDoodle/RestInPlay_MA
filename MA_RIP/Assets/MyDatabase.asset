      - title: Menu Text
        value: 
        type: 0
        typeString: 
      - title: Dialogue Text
        value: 'Now, let me explain why I am here:'
        type: 0
        typeString: 
      - title: Sequence
        value: SetActive(DeathEyesClosedfalse);SetActive(DeathSmirk,false);SetActive(Death,false);SetActive(DeathExplain,true);
