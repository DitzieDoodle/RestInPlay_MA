        y: 2832.1636
        width: 160
        height: 30
    - id: 38
      fields:
      - title: Title
        value: 
        type: 0
        typeString: 
      - title: Description
        value: 
        type: 0
        typeString: 
      - title: Actor
        value: 7
        type: 5
        typeString: CustomFieldType_Actor
      - title: Conversant
        value: 4
        type: 5
        typeString: CustomFieldType_Actor
      - title: Menu Text
        value: 
        type: 0
        typeString: 
      - title: Dialogue Text
        value: I will allow you to visit them as they prepare for your funeral. Listen
          to their words, to what they feel. Help them untangle their emotions for
          a while, and gently guide them through these final, difficult decisions.
        type: 0
        typeString: 
      - title: Sequence
        value: 
        type: 0
        typeString: 
      conversationID: 1
      isRoot: 0
      isGroup: 0
      nodeColor: 
