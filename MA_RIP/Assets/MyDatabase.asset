      conditionPriority: 2
      outgoingLinks:
      - originConversationID: 1
        originDialogueID: 36
        destinationConversationID: 1
        destinationDialogueID: 37
        isConnector: 0
        priority: 2
      conditionsString: 
      userScript: 
      onExecute:
        m_PersistentCalls:
          m_Calls: []
      canvasRect:
        serializedVersion: 2
