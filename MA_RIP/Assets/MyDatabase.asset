        value: 
        type: 0
        typeString: 
      - title: Description
        value: 
        type: 0
        typeString: 
      - title: Actor
        value: 7
        type: 5
        typeString: CustomFieldType_Actor
      - title: Conversant
        value: 4
        type: 5
        typeString: CustomFieldType_Actor
      - title: Menu Text
        value: 
        type: 0
        typeString: 
      - title: Dialogue Text
        value: "It seems neither you nor your family ever spoke of me, or of the
          consequences that follow a person\u2019s death."
        type: 0
        typeString: 
      - title: Sequence
        value: SetActive(DeathExplain,false);SetActive(DeathRead,true);
        type: 0
