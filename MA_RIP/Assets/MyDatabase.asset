        value: 4
        type: 5
        typeString: CustomFieldType_Actor
      - title: Menu Text
        value: 
        type: 0
        typeString: 
      - title: Dialogue Text
        value: Sadly, this is very common and it only makes my work more difficult.
        type: 0
        typeString: 
      - title: Sequence
        value: SetActive(DeathRead,false);SetActive(Death,true);
        type: 0
        typeString: 
